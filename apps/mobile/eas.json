{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "gradleCommand": ":app:assembleDebug" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "20.20.2",
      "pnpm": "9.12.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.clary.uz"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "node": "20.20.2",
      "pnpm": "9.12.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.clary.uz"
      },
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ops@clary.uz",
        "ascAppId": "0000000000"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}

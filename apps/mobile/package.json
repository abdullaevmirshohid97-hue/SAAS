{
  "name": "@clary/mobile",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "echo 'Mobile build handled by EAS. Use pnpm -F @clary/mobile start for local dev.'",
    "build:export": "expo export",
    "build:eas": "eas build --platform all",
    "build:eas:preview": "eas build --profile preview --platform android --non-interactive",
    "publish:preview": "node ../../scripts/publish-mobile-version.mjs --app=patient-mobile --channel=preview",
    "build:eas:production": "eas build --profile production --platform all --non-interactive",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "jest"
  },
  "dependencies": {
    "@clary/api-client": "workspace:*",
    "@clary/i18n": "workspace:*",
    "@expo/vector-icons": "^14.0.2",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.51.1",
    "expo": "~51.0.28",
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "expo-local-authentication": "~14.0.1",
    "expo-localization": "~15.0.3",
    "expo-notifications": "~0.28.16",
    "expo-router": "~3.5.21",
    "expo-splash-screen": "~0.27.5",
    "expo-status-bar": "~1.12.1",
    "expo-updates": "~0.25.22",
    "nativewind": "^4.1.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.3",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@clary/tsconfig": "workspace:*",
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  }
}

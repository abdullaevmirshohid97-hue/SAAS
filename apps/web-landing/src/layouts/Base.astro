---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatingCta from '../components/FloatingCta.astro';
import Telemetry from '../components/Telemetry.astro';
import { ExitIntent } from '../components/ExitIntent';
import { CookieConsent } from '../components/CookieConsent';
import { buildHreflang, canonicalFor } from '../lib/seo';

export interface Props {
  title?: string;
  description?: string;
  /** Qo'lda canonical kerak bo'lsa — aks holda yo'ldan avtomatik hisoblanadi. */
  canonical?: string;
  locale?: string;
  image?: string;
  /** Sahifa breadcrumb zanjiri — BreadcrumbList JSON-LD uchun. */
  breadcrumbs?: Array<{ name: string; url: string }>;
  /** FAQ ro'yxati — FAQPage JSON-LD uchun (AI qidiruv va rich results). */
  faq?: Array<{ question: string; answer: string }>;
  /** true bo'lsa sahifa indekslanmaydi (signup, demo kabi). */
  noindex?: boolean;
}

const {
  title = 'Clary — Enterprise clinic management SaaS',
  description = 'Klinikangizni bir joydan boshqaring. Multi-tenant, catalog-driven SaaS for Uzbekistan and CIS.',
  canonical,
  locale = 'uz-Latn',
  image = '/og-default.png',
  breadcrumbs,
  faq,
  noindex = false,
} = Astro.props;

const year = new Date().getFullYear();

// Canonical va hreflang — sahifa yo'lidan avtomatik (SEO xatosini tuzatadi).
const pathname = Astro.url.pathname;
const canonicalUrl = canonical ?? canonicalFor(pathname);
const hreflangLinks = buildHreflang(pathname);
// og:image absolyut URL bo'lishi shart — Facebook/Telegram nisbiy yo'lni o'qimaydi.
const imageUrl = new URL(image, Astro.site ?? 'https://clary.uz').href;

// JSON-LD resurslar
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Clary',
  url: 'https://clary.uz',
  logo: 'https://clary.uz/logo.svg',
  email: 'clarysupport@gmail.com',
  address: { '@type': 'PostalAddress', addressCountry: 'UZ', addressLocality: 'Tashkent' },
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Clary',
  url: 'https://clary.uz',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://clary.uz/blog?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Clary',
  operatingSystem: 'Web, iOS, Android',
  applicationCategory: 'BusinessApplication',
  description,
  offers: [
    { '@type': 'Offer', price: '0', priceCurrency: 'USD', name: 'Demo — 3 kun bepul' },
    { '@type': 'Offer', price: '25', priceCurrency: 'USD', name: 'Base' },
    { '@type': 'Offer', price: '50', priceCurrency: 'USD', name: 'Pro' },
    { '@type': 'Offer', price: '120', priceCurrency: 'USD', name: 'Enterprise' },
  ],
};

const breadcrumbLd = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: b.url,
      })),
    }
  : null;

const faqLd = faq && faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    }
  : null;
---
<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#2563EB" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Clary" />

    <!-- OpenGraph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={locale.replace('-', '_')} />
    <meta property="og:site_name" content="Clary" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- hreflang alternates — har sahifa o'zining locale variantlariga -->
    {hreflangLinks.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={l.href} />
    ))}

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
    {breadcrumbLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}
    {faqLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    )}

    <Telemetry />
  </head>
  <body class="min-h-screen font-sans antialiased">
    <Nav />
    <slot />
    <FloatingCta />
    <ExitIntent client:idle />
    <CookieConsent client:idle />
    <Footer year={year} />
  </body>
</html>

---
import Base from '../layouts/Base.astro';
---
<Base title="Sheriklar — Clary" description="Clary bilan hamkorlik dasturi: implementatsiya sheriklari, reseller dastur va affiliate.">
  <section class="container mx-auto max-w-5xl px-4 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold sm:text-5xl">Sheriklik dasturi</h1>
      <p class="mt-4 text-muted-foreground">Klinikangizga Clary tatbiq qiling, mijozlar uchun yechimlar yarating va rivojlanishimizda hamkor bo'ling</p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <div class="rounded-xl border bg-card p-6">
        <div class="text-3xl">🤝</div>
        <h3 class="mt-3 text-lg font-semibold">Implementation Partner</h3>
        <p class="mt-2 text-sm text-muted-foreground">Klinikalarga Clary tatbiq qilish, migratsiya, training va support xizmati.</p>
        <ul class="mt-4 space-y-1 text-sm text-muted-foreground">
          <li>✓ 30% komissiya birinchi 12 oy</li>
          <li>✓ Texnik training va sertifikat</li>
          <li>✓ White-label demo akkaunt</li>
        </ul>
      </div>
      <div class="rounded-xl border bg-card p-6">
        <div class="text-3xl">💼</div>
        <h3 class="mt-3 text-lg font-semibold">Reseller</h3>
        <p class="mt-2 text-sm text-muted-foreground">O'z brendingiz bilan Clary'ni sotish va qo'llab-quvvatlash.</p>
        <ul class="mt-4 space-y-1 text-sm text-muted-foreground">
          <li>✓ Reseller margin 25–40%</li>
          <li>✓ Hududiy eksklyuzivlik</li>
          <li>✓ Co-branded materiallar</li>
        </ul>
      </div>
      <div class="rounded-xl border bg-card p-6">
        <div class="text-3xl">🔗</div>
        <h3 class="mt-3 text-lg font-semibold">Affiliate</h3>
        <p class="mt-2 text-sm text-muted-foreground">Tavsiya havolasi orqali doimiy passive income.</p>
        <ul class="mt-4 space-y-1 text-sm text-muted-foreground">
          <li>✓ 20% recurring commission</li>
          <li>✓ Real-time analytics dashboard</li>
          <li>✓ Marketing materiallari</li>
        </ul>
      </div>
    </div>

    <div class="mt-16 rounded-xl border bg-gradient-to-br from-[#2563EB] to-[#1D4ED8] p-10 text-center text-white">
      <h2 class="text-2xl font-bold">Sherik bo'ling</h2>
      <p class="mt-2 opacity-90">Birgalikda O'zbekistondagi har bir klinikani raqamlashtiraylik</p>
      <a href="/contact?topic=partners" class="mt-6 inline-block rounded-md bg-white px-6 py-3 text-sm font-semibold text-[#2563EB] hover:bg-neutral-100">Murojaat qoldirish &rarr;</a>
    </div>
  </section>
</Base>

---
import Base from '../layouts/Base.astro';
const plans = [
  { code: 'demo',   name: 'Demo',       price: 0,   desc: '14 kun bepul', staff: '2',        devices: '2',        features: ['Barcha asosiy imkoniyatlar','Kartakuz so’ralmaydi'] },
  { code: '25pro',  name: 'Starter',    price: 25,  desc: '/oy',          staff: '2',        devices: '2',        features: ['Qabulxona + Kassa','Navbat + bemorlar bazasi','Dorixona POS','SMS eslatmalar (BYO)'] },
  { code: '50pro',  name: 'Business',   price: 50,  desc: '/oy',          staff: '10',       devices: '10',       features: ['25PRO + hammasi','Custom rollar yo’q','Advanced analitika','Email shablonlari'], featured: true },
  { code: '120pro', name: 'Enterprise', price: 120, desc: '/oy',          staff: 'Cheksiz',  devices: 'Cheksiz',  features: ['50PRO + hammasi','Custom rollar','SLA (99.9% uptime)','Prioritet support'] },
];
---
<Base title="Tariflar — Clary" description="Demo, 25PRO, 50PRO, 120PRO tariflari. Oshkora narxlar, yashirin to'lovlar yo'q.">
  <section class="container mx-auto px-4 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold sm:text-5xl">Sodda, oshkora tariflar</h1>
      <p class="mt-4 text-muted-foreground">Klinikangizning hajmiga mos tarifni tanlang</p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {plans.map((p) => (
        <div class={`card-hover rounded-xl border bg-card p-7 ${p.featured ? 'border-[#2563EB] ring-2 ring-[#2563EB]/20' : ''}`}>
          {p.featured && <div class="mb-3 inline-block rounded-full bg-[#2563EB] px-3 py-0.5 text-xs font-semibold text-white">Tavsiya etilgan</div>}
          <div class="text-lg font-semibold">{p.name}</div>
          <div class="mt-3 flex items-baseline">
            <span class="text-4xl font-bold">${p.price}</span>
            <span class="ml-1 text-muted-foreground">{p.desc}</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm">
            <li class="flex gap-2"><span class="text-[#10B981]">&#10003;</span> {p.staff} xodim</li>
            <li class="flex gap-2"><span class="text-[#10B981]">&#10003;</span> {p.devices} qurilma</li>
            {p.features.map((f) => <li class="flex gap-2"><span class="text-[#10B981]">&#10003;</span> {f}</li>)}
          </ul>
          <a href={`/signup?plan=${p.code}`} class={`mt-8 block rounded-md px-4 py-2.5 text-center text-sm font-semibold ${p.featured ? 'bg-[#2563EB] text-white hover:bg-[#1D4ED8]' : 'border hover:bg-accent'}`}>Boshlash</a>
        </div>
      ))}
    </div>
  </section>
</Base>

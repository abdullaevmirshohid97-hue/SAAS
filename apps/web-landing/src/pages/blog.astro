---
import Base from '../layouts/Base.astro';
import { fetchSiteContent, getString, type SiteEntry } from '../lib/cms';

const cms = await fetchSiteContent('uz-Latn');
const posts: SiteEntry[] = (cms?.by_kind?.['post'] ?? [])
  .slice()
  .sort((a, b) => a.sort_order - b.sort_order);

const fallbackPosts = [
  { slug: 'klinika-boshqaruv-2026', title: 'Klinika boshqaruv tizimi 2026: nimaga e\'tibor berish kerak', excerpt: "Excel'dan zamonaviy SaaS'ga o'tayotgan klinika rahbari uchun 7 ta asosiy mezon.", date: '2026-05-04', category: 'Strategiya' },
  { slug: 'exceldan-clary-7-kun', title: "Excel'dan Clary'ga 7 kunda: amaliy plan", excerpt: "Klinika ma'lumotlarini ko'chirishning kun-kun bo'lib taqsimlangan rejasi.", date: '2026-05-03', category: "Qo'llanma" },
  { slug: 'bemor-tajribasi-10-maslahat', title: "Bemor tajribasini yaxshilash: 10 amaliy maslahat", excerpt: 'Qaytish koeffitsientini 40% gacha oshirish uchun isbotlangan amaliyotlar.', date: '2026-05-02', category: 'Operatsiyalar' },
];

const items = posts.length
  ? posts.map((p) => ({
      slug: (p.data?.slug as string) ?? p.key.replace(/^post\./, ''),
      title: getString(p, 'title', p.key),
      excerpt: getString(p, 'excerpt'),
      date: (p.data?.date as string) ?? '',
      category: (p.data?.category as string) ?? 'Blog',
    }))
  : fallbackPosts;
---
<Base title="Blog — Clary" description="Yangiliklar, qo'llanmalar va texnologiya bo'yicha maqolalar.">
  <section class="container mx-auto max-w-5xl px-4 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold sm:text-5xl">Blog</h1>
      <p class="mt-4 text-muted-foreground">Mahsulot yangiliklari, qo'llanmalar va sanoat tahlillari</p>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {items.map((p) => (
        <a href={`/blog/${p.slug}`} class="card-hover block rounded-xl border bg-card p-6">
          <div class="text-xs font-medium uppercase tracking-wider text-[#2563EB]">{p.category}</div>
          <h3 class="mt-2 text-lg font-semibold leading-snug">{p.title}</h3>
          <p class="mt-2 line-clamp-3 text-sm text-muted-foreground">{p.excerpt}</p>
          {p.date && <div class="mt-4 text-xs text-muted-foreground">{p.date}</div>}
        </a>
      ))}
    </div>
    {items.length === 0 && (
      <p class="mt-16 text-center text-muted-foreground">Tez orada birinchi maqolalar paydo bo‘ladi.</p>
    )}
  </section>
</Base>

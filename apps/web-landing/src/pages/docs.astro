---
import Base from '../layouts/Base.astro';
import { fetchSiteContent, getString, type SiteEntry } from '../lib/cms';
import { DOC_PAGES, DOC_SECTION_ORDER } from '../data/docs';

const cms = await fetchSiteContent('uz-Latn');
const docs: SiteEntry[] = (cms?.by_kind?.['doc'] ?? [])
  .slice()
  .sort((a, b) => a.sort_order - b.sort_order);

// CMS hujjatlari + evergreen cornerstone (docs.ts) birlashtiriladi: CMS slug
// ustun, evergreen faqat CMS'da yo'q bo'lsa qo'shiladi. Bo'limlar bo'yicha
// guruhlanadi; DOC_SECTION_ORDER tartibi saqlanadi.
type SectionMap = Map<string, { title: string; items: Array<{ slug: string; title: string }> }>;
const grouped: SectionMap = new Map();
function addItem(section: string, slug: string, title: string) {
  if (!grouped.has(section)) grouped.set(section, { title: section, items: [] });
  grouped.get(section)!.items.push({ slug, title });
}

const cmsSlugs = new Set<string>();
for (const d of docs) {
  const slug = (d.data?.slug as string) ?? d.key.replace(/^doc\./, '');
  cmsSlugs.add(slug);
  addItem((d.data?.section as string) ?? 'Hujjatlar', slug, getString(d, 'title', d.key));
}
for (const d of DOC_PAGES) {
  if (!cmsSlugs.has(d.slug)) addItem(d.section, d.slug, d.title);
}

const sections = Array.from(grouped.values()).sort((a, b) => {
  const ia = DOC_SECTION_ORDER.indexOf(a.title);
  const ib = DOC_SECTION_ORDER.indexOf(b.title);
  return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
});
---
<Base title="Hujjatlar — Clary" description="Clary platformasidan to'liq foydalanish bo'yicha rasmiy hujjatlar.">
  <section class="container mx-auto max-w-5xl px-4 py-16">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold sm:text-5xl">Hujjatlar</h1>
      <p class="mt-4 text-muted-foreground">Boshlash, modullar, integratsiyalar va API havolalari</p>
    </div>

    <div class="mt-10 max-w-xl mx-auto">
      <input type="search" placeholder="Qidirish…" class="h-11 w-full rounded-md border bg-background px-4 text-sm" />
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {sections.map((s) => (
        <div class="rounded-xl border bg-card p-6">
          <h2 class="text-lg font-semibold">{s.title}</h2>
          <ul class="mt-4 space-y-2 text-sm">
            {s.items.map((it) => (
              <li>
                <a href={`/docs/${it.slug}`} class="text-muted-foreground hover:text-[#2563EB]">{it.title}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Base>

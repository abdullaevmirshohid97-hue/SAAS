---
import Base from '../layouts/Base.astro';
import { fetchSiteContent, getString, type SiteEntry } from '../lib/cms';

const locale = 'uz-Latn';
const cms = await fetchSiteContent(locale);
const feats: SiteEntry[] = (cms?.by_kind['feature_detail'] ?? []).slice().sort((a, b) => a.sort_order - b.sort_order);

const fallbacks = [
  { slug: 'diagnostics', title: 'Diagnostika', excerpt: 'X-Ray, CT, MRI, USG, ECG', icon: '🔬' },
  { slug: 'pharmacy', title: 'Dorixona', excerpt: 'POS + ombor + FIFO', icon: '💊' },
  { slug: 'lab', title: 'Laboratoriya', excerpt: 'Testlar + natijalar', icon: '🧪' },
  { slug: 'inpatient', title: 'Statsionar', excerpt: 'Xonalar + vitals', icon: '🏨' },
  { slug: 'analytics', title: 'Analitika', excerpt: 'Daromad, konversiya', icon: '📊' },
  { slug: 'marketing', title: 'Marketing 2.0', excerpt: 'Segmentlar, kampaniyalar', icon: '📣' },
  { slug: 'queue', title: 'Navbat', excerpt: 'QR-kiosk, online booking', icon: '📅' },
];

const items =
  feats.length > 0
    ? feats.map((f) => ({
        slug: (f.data?.slug as string | undefined) ?? f.key.replace(/^feature_detail\./, ''),
        title: getString(f, 'title'),
        excerpt: getString(f, 'excerpt') || getString(f, 'subtitle'),
        icon: (f.data?.icon as string | undefined) ?? '✨',
      }))
    : fallbacks;
---
<Base title="Imkoniyatlar — Clary" description="Clary platformasining barcha modullari va funksiyalari.">
  <section class="container mx-auto max-w-6xl px-4 py-16">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Barcha imkoniyatlar</h1>
      <p class="mt-4 text-muted-foreground">12+ modul — bitta tizimda</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {items.map((it) => (
        <a href={`/features/${it.slug}`} class="card-hover block rounded-xl border bg-card p-6">
          <div class="text-4xl">{it.icon}</div>
          <h3 class="mt-3 text-lg font-semibold">{it.title}</h3>
          <p class="mt-1 text-sm text-muted-foreground">{it.excerpt}</p>
          <div class="mt-4 text-sm font-semibold text-[#2563EB]">Batafsil →</div>
        </a>
      ))}
    </div>
  </section>
</Base>

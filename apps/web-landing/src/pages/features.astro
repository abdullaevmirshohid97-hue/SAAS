---
import Base from '../layouts/Base.astro';
import { fetchSiteContent, getSeoOverride, getString, type SiteEntry } from '../lib/cms';

const locale = 'uz-Latn';
const cms = await fetchSiteContent(locale);
const seo = getSeoOverride(cms, '/features');
const feats: SiteEntry[] = (cms?.by_kind['feature_detail'] ?? []).slice().sort((a, b) => a.sort_order - b.sort_order);

const fallbacks = [
  { slug: 'diagnostics', title: 'Diagnostika', excerpt: 'X-Ray, CT, MRI, USG, ECG', icon: '🔬' },
  { slug: 'pharmacy', title: 'Dorixona', excerpt: 'POS + ombor + FIFO', icon: '💊' },
  { slug: 'lab', title: 'Laboratoriya', excerpt: 'Testlar + natijalar', icon: '🧪' },
  { slug: 'inpatient', title: 'Statsionar', excerpt: 'Xonalar + vitals', icon: '🏨' },
  { slug: 'analytics', title: 'Analitika', excerpt: 'Daromad, konversiya', icon: '📊' },
  { slug: 'marketing', title: 'Marketing 2.0', excerpt: 'Segmentlar, kampaniyalar', icon: '📣' },
  { slug: 'queue', title: 'Navbat', excerpt: 'QR-kiosk, online booking', icon: '📅' },
];

const items =
  feats.length > 0
    ? feats.map((f) => ({
        slug: (f.data?.slug as string | undefined) ?? f.key.replace(/^feature_detail\./, ''),
        title: getString(f, 'title'),
        excerpt: getString(f, 'excerpt') || getString(f, 'subtitle'),
        icon: (f.data?.icon as string | undefined) ?? '✨',
      }))
    : fallbacks;
---
<Base
  title={seo?.title ?? 'Imkoniyatlar — Clary'}
  description={seo?.description ?? 'Clary platformasining barcha modullari va funksiyalari.'}
  image={seo?.ogImage}
>
  <section class="container mx-auto max-w-6xl px-4 py-16">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Barcha imkoniyatlar</h1>
      <p class="mt-4 text-muted-foreground">12+ modul — bitta tizimda</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {items.map((it) => (
        <a href={`/features/${it.slug}`} class="card-hover block rounded-xl border bg-card p-6">
          <div class="text-4xl">{it.icon}</div>
          <h3 class="mt-3 text-lg font-semibold">{it.title}</h3>
          <p class="mt-1 text-sm text-muted-foreground">{it.excerpt}</p>
          <div class="mt-4 text-sm font-semibold text-[#2563EB]">Batafsil →</div>
        </a>
      ))}
    </div>

    {/* Internal linking — sohaga oid yechim sahifalariga */}
    <div class="mt-16 rounded-2xl border bg-muted/20 p-8">
      <h2 class="text-2xl font-bold tracking-tight">Sohangizga mos yechimni toping</h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Clary klinika, laboratoriya, stomatologiya va diagnostika markazlari uchun.
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <a href="/solutions/klinika-dasturi" class="rounded-full border bg-card px-4 py-1.5 text-sm hover:border-[#2563EB] hover:text-[#2563EB]">Klinika dasturi</a>
        <a href="/solutions/laboratoriya-dasturi" class="rounded-full border bg-card px-4 py-1.5 text-sm hover:border-[#2563EB] hover:text-[#2563EB]">Laboratoriya dasturi</a>
        <a href="/solutions/stomatologiya-dasturi" class="rounded-full border bg-card px-4 py-1.5 text-sm hover:border-[#2563EB] hover:text-[#2563EB]">Stomatologiya dasturi</a>
        <a href="/solutions/diagnostika-markazi-dasturi" class="rounded-full border bg-card px-4 py-1.5 text-sm hover:border-[#2563EB] hover:text-[#2563EB]">Diagnostika markazi</a>
        <a href="/solutions" class="rounded-full border bg-card px-4 py-1.5 text-sm hover:border-[#2563EB] hover:text-[#2563EB]">Barcha yechimlar</a>
        <a href="/vs" class="rounded-full border bg-card px-4 py-1.5 text-sm hover:border-[#2563EB] hover:text-[#2563EB]">Taqqoslash</a>
      </div>
    </div>
  </section>
</Base>

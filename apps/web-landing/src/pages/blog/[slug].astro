---
import Base from '../../layouts/Base.astro';
import { fetchSiteContent, getString, type SiteEntry } from '../../lib/cms';
import { BLOG_POSTS, BLOG_POSTS_BY_SLUG } from '../../data/posts';

export async function getStaticPaths() {
  const cms = await fetchSiteContent('uz-Latn');
  const posts: SiteEntry[] = cms?.by_kind?.['post'] ?? [];
  const fromCms = posts.map((p) => ({
    params: { slug: (p.data?.slug as string) ?? p.key.replace(/^post\./, '') },
    props: { entry: p, fallback: null },
  }));
  // CMS + evergreen cornerstone (posts.ts) birlashtiriladi — CMS slug ustun.
  const cmsSlugs = new Set(fromCms.map((p) => p.params.slug));
  const fromEvergreen = BLOG_POSTS.filter((p) => !cmsSlugs.has(p.slug)).map((p) => ({
    params: { slug: p.slug },
    props: { entry: null, fallback: p },
  }));
  return [...fromCms, ...fromEvergreen];
}

const { slug } = Astro.params;
const { entry } = Astro.props as { entry: SiteEntry | null };
// Fallback'ni slug bo'yicha olamiz — getStaticPaths props'iga tayanmaymiz
// (CMS yo'lida fallback null; statik yo'lda BLOG_POSTS_BY_SLUG topadi).
const fallback = entry ? null : (BLOG_POSTS_BY_SLUG[slug ?? ''] ?? null);

const title = entry ? getString(entry, 'title', slug ?? 'Blog') : (fallback?.title ?? slug ?? 'Blog');
const body = entry ? getString(entry, 'body', '') : (fallback?.bodyHtml ?? '');
const excerpt = entry ? getString(entry, 'excerpt', '') : (fallback?.excerpt ?? '');
const date = (entry?.data?.date as string | undefined) ?? fallback?.date ?? '';
const author = (entry?.data?.author as string | undefined) ?? fallback?.author ?? 'Clary jamoasi';
const category = (entry?.data?.category as string | undefined) ?? fallback?.category ?? 'Blog';
// Individual OG rasm — CMS post entrysining data.og_image maydoni (ixtiyoriy).
const ogImage = (entry?.data?.og_image as string | undefined) || undefined;

// BreadcrumbList JSON-LD uchun
const breadcrumbs = [
  { name: 'Bosh sahifa', url: 'https://clary.uz/' },
  { name: 'Blog', url: 'https://clary.uz/blog' },
  { name: title, url: `https://clary.uz/blog/${slug}` },
];
---

<Base title={`${title} — Clary Blog`} description={excerpt || title} breadcrumbs={breadcrumbs} image={ogImage}>
  <article class="container mx-auto max-w-3xl px-4 py-20">
    <a href="/blog" class="text-sm text-[#2563EB] hover:underline">&larr; Blog</a>
    <div class="mt-6 text-xs font-semibold uppercase tracking-wider text-[#2563EB]">{category}</div>
    <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
    <div class="mt-3 text-sm text-muted-foreground">{author}{date ? ` · ${date}` : ''}</div>
    {body ? (
      <div class="prose prose-neutral mt-10 max-w-none prose-headings:font-bold prose-h2:mt-10 prose-h2:text-2xl prose-a:text-[#2563EB] prose-p:leading-relaxed" set:html={body}></div>
    ) : (
      <p class="mt-10 text-muted-foreground">Maqola tez orada e'lon qilinadi.</p>
    )}

    <div class="mt-16 rounded-2xl border bg-gradient-to-br from-[#2563EB] to-[#1D4ED8] p-8 text-center text-white">
      <h3 class="text-xl font-bold sm:text-2xl">Klinikangizni Clary bilan boshqarib ko'ring</h3>
      <p class="mt-2 text-sm opacity-90">14 kun bepul · Karta kerak emas · 5 daqiqada</p>
      <a href="/demo" class="mt-5 inline-block rounded-md bg-white px-6 py-2.5 text-sm font-semibold text-[#2563EB] hover:bg-neutral-100">
        Bepul demo &rarr;
      </a>
    </div>
  </article>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description: excerpt,
      author: { '@type': 'Organization', name: author },
      datePublished: date || undefined,
      image: ogImage ?? 'https://clary.uz/og-default.png',
      publisher: { '@type': 'Organization', name: 'Clary', logo: { '@type': 'ImageObject', url: 'https://clary.uz/logo.svg' } },
    })}
  />
</Base>

---
import Base from '../../layouts/Base.astro';

// Soxta hikoyalar olib tashlandi — haqiqiy mijoz case-study'lari shu yerga qo'shiladi.
const studies: Array<{
  slug: string;
  clinic: string;
  location: string;
  headline: string;
  metric: string;
}> = [];
---

<Base
  title="Mijoz hikoyalari — Clary"
  description="Clary bilan ishlaydigan klinikalar haqida real case study'lar va natijalar."
>
  <section class="container mx-auto max-w-5xl px-4 py-20">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[#2563EB]">Case Studies</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Mijoz hikoyalari</h1>
      <p class="mt-4 text-muted-foreground">Real klinikalar, real raqamlar, real o'zgarishlar</p>
    </div>

    {studies.length === 0 ? (
      <div class="mt-12 rounded-xl border border-dashed bg-muted/20 p-12 text-center text-muted-foreground">
        Tez orada — haqiqiy mijoz hikoyalari shu yerda chop etiladi.
      </div>
    ) : (
    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {studies.map((s) => (
        <a
          href={`/case-studies/${s.slug}`}
          class="group card-hover flex flex-col rounded-xl border bg-card p-6"
        >
          <div class="text-sm text-muted-foreground">{s.location}</div>
          <h2 class="mt-2 text-xl font-semibold group-hover:text-[#2563EB]">{s.clinic}</h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed">{s.headline}</p>
          <div class="mt-4 flex items-center justify-between border-t pt-4">
            <span class="rounded-full bg-[#10B981]/10 px-2.5 py-1 text-xs font-semibold text-[#10B981]">
              ★ {s.metric}
            </span>
            <span class="text-sm font-semibold text-[#2563EB]">O'qish &rarr;</span>
          </div>
        </a>
      ))}
    </div>
    )}
  </section>
</Base>

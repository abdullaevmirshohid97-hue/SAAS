---
import Base from '../layouts/Base.astro';
---
<Base title="Ro'yxatdan o'tish — Clary">
  <section class="container mx-auto max-w-md px-4 py-20">
    <h1 class="text-3xl font-bold">Bepul hisob yarating</h1>
    <p class="mt-2 text-muted-foreground">Demo 3 kun bepul. Kredit karta kerak emas.</p>

    <!-- Google bilan ro'yxatdan o'tish — clinic app OAuth oqimiga delegatsiya -->
    <a
      href="https://app.clary.uz/login?signup=google"
      class="mt-8 flex w-full items-center justify-center gap-2 rounded-md border px-4 py-2.5 text-sm font-semibold hover:bg-accent"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09Z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
        <path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"/>
      </svg>
      Google bilan davom etish
    </a>

    <div class="my-5 flex items-center gap-3 text-xs text-muted-foreground">
      <span class="h-px flex-1 bg-border"></span>
      yoki email bilan
      <span class="h-px flex-1 bg-border"></span>
    </div>

    <form id="signup-form" class="space-y-4">
      <div>
        <label class="text-sm font-medium">To'liq ism</label>
        <input type="text" name="fullName" required class="mt-1 w-full rounded-md border px-3 py-2" />
      </div>
      <div>
        <label class="text-sm font-medium">Email</label>
        <input type="email" name="email" required class="mt-1 w-full rounded-md border px-3 py-2" />
      </div>
      <div>
        <label class="text-sm font-medium">Parol</label>
        <input type="password" name="password" required minlength="8" class="mt-1 w-full rounded-md border px-3 py-2" />
      </div>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="accept" required />
        <span><a href="/legal/terms" class="text-[#2563EB] underline">Shartlar</a> va <a href="/legal/privacy" class="text-[#2563EB] underline">Maxfiylik siyosati</a>ga roziman</span>
      </label>
      <button type="submit" class="w-full rounded-md bg-[#2563EB] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#1D4ED8]">
        Ro'yxatdan o'tish
      </button>
    </form>

    <p class="mt-4 text-center text-sm text-muted-foreground">
      Allaqachon hisobingiz bormi? <a href="https://app.clary.uz/login" class="text-[#2563EB]">Kirish</a>
    </p>
  </section>

  <script>
    const form = document.getElementById('signup-form') as HTMLFormElement | null;
    const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (btn) { btn.disabled = true; btn.textContent = 'Yuklanmoqda…'; }

      const fd = new FormData(e.target as HTMLFormElement);
      // Boshqa landing sahifalar bilan bir xil API manzili (ASTRO_PUBLIC_API_URL
      // build vaqtida bo'lmasligi mumkin — window.PUBLIC_API_URL ishonchli).
      const apiBase =
        (window as unknown as { PUBLIC_API_URL?: string }).PUBLIC_API_URL ||
        'https://api.clary.uz';
      const res = await fetch(`${apiBase}/api/v1/public/signup`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fullName: fd.get('fullName'),
          email: fd.get('email'),
          password: fd.get('password'),
          acceptedTerms: true,
          turnstileToken: 'dev-skip',
        }),
      });

      if (res.ok) {
        const json = await res.json() as { magic_link?: string; next?: string };
        // magic_link → auto-login + redirect to onboarding
        // next      → fallback, user signs in manually
        window.location.href = json.magic_link ?? json.next ?? 'https://app.clary.uz/onboarding';
      } else {
        if (btn) { btn.disabled = false; btn.textContent = "Ro'yxatdan o'tish"; }
        const err = await res.json().catch(() => ({ error: { message: 'Xato' } })) as { error?: { message?: string } };
        alert(err.error?.message ?? 'Xato yuz berdi');
      }
    });
  </script>
</Base>

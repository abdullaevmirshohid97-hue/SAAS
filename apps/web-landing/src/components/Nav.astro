---
import {
  SUPPORTED_LOCALES,
  LOCALE_LABELS,
  LOCALE_FLAGS,
  DEFAULT_LOCALE,
  isSupportedLocale,
} from '../lib/locales';

const params = Astro.params as Record<string, string | undefined>;
const currentLocale = isSupportedLocale(params.locale) ? params.locale : DEFAULT_LOCALE;
const prefix = currentLocale === DEFAULT_LOCALE ? '' : `/${currentLocale}`;
---
<header class="sticky top-0 z-40 w-full border-b border-border/40 bg-background/80 backdrop-blur-lg">
  <div class="container mx-auto flex h-14 items-center justify-between px-4">
    <a href={prefix + '/'} class="flex items-center gap-2 font-semibold">
      <div class="h-7 w-7 rounded bg-[#2563EB]"></div>
      <span>Clary</span>
    </a>
    <nav class="hidden items-center gap-6 text-sm md:flex">
      <a href={prefix + '/features'} class="text-muted-foreground transition-colors hover:text-foreground">Imkoniyatlar</a>
      <a href={prefix + '/pricing'} class="text-muted-foreground transition-colors hover:text-foreground">Tariflar</a>
      <a href={prefix + '/use-cases'} class="text-muted-foreground transition-colors hover:text-foreground">Foydalanish</a>
      <a href={prefix + '/blog'} class="text-muted-foreground transition-colors hover:text-foreground">Blog</a>
      <a href={prefix + '/docs'} class="text-muted-foreground transition-colors hover:text-foreground">Hujjatlar</a>
      <a href={prefix + '/download'} class="text-muted-foreground transition-colors hover:text-foreground">Bemor ilovasi</a>
    </nav>
    <div class="flex items-center gap-2">
      <details class="relative hidden md:block">
        <summary class="flex cursor-pointer items-center gap-1 rounded-md border px-2 py-1 text-sm hover:bg-accent">
          <span>{LOCALE_FLAGS[currentLocale]}</span>
          <span>{LOCALE_LABELS[currentLocale]}</span>
          <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </summary>
        <div class="absolute right-0 z-50 mt-1 min-w-[180px] rounded-md border bg-background py-1 shadow-lg">
          {SUPPORTED_LOCALES.map((loc) => {
            const href = loc === DEFAULT_LOCALE ? '/' : `/${loc}/`;
            return (
              <a href={href} class={`flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-accent ${loc === currentLocale ? 'font-semibold' : ''}`}>
                <span>{LOCALE_FLAGS[loc]}</span>
                <span>{LOCALE_LABELS[loc]}</span>
              </a>
            );
          })}
        </div>
      </details>
      <a href="https://app.clary.uz/login" class="hidden rounded-md px-3 py-1.5 text-sm font-medium hover:bg-accent sm:inline-block">Kirish</a>
      <a href={prefix + '/signup'} class="rounded-md bg-[#2563EB] px-4 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-[#1D4ED8]">Bepul boshlash</a>
    </div>
  </div>
</header>

---
type Testimonial = {
  name: string;
  role: string;
  clinic: string;
  quote: string;
  metric?: string;
  initials: string;
  accent: string;
};

const items: Testimonial[] = [
  {
    name: 'Dilshod Abdullayev',
    role: 'Bosh shifokor',
    clinic: 'NUR Klinika · Toshkent',
    quote:
      "Excel va daftardan voz kechib, Clary'ga o'tdik. Bemor qabuli 40% tezlashdi, hisobot tayyorlash 3 soatdan 10 daqiqaga tushdi.",
    metric: 'Qabul vaqti −40%',
    initials: 'DA',
    accent: '#2563EB',
  },
  {
    name: "Nodira Karimova",
    role: 'Direktor',
    clinic: 'Diagnostika Markaz · Samarqand',
    quote:
      "Click va Payme bir tugmada ulandi, kassa bo'limi xatosi nolga tushdi. AI hisoboti har kuni ertalab nimaga e'tibor berishni aytadi.",
    metric: 'Kassa xatosi 0%',
    initials: 'NK',
    accent: '#10B981',
  },
  {
    name: 'Sardor Yusupov',
    role: 'IT direktor',
    clinic: 'MedPlus Group · Buxoro',
    quote:
      "Bir hafta ichida 12 ta filialni bitta tizimga ko'chirdik. RLS va audit log tufayli compliance auditdan birinchi urinishda o'tdik.",
    metric: '12 filial · 7 kun',
    initials: 'SY',
    accent: '#8B5CF6',
  },
];
---

<section class="bg-muted/20 py-20" id="testimonials">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[#2563EB]">Mijozlar fikri</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Real klinikalar — real natijalar</h2>
      <p class="mt-4 text-muted-foreground">Clary bilan ishlayotgan klinika rahbarlari nima deydi</p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {items.map((t) => (
        <figure class="card-hover flex flex-col rounded-xl border bg-card p-6">
          {t.metric && (
            <div
              class="mb-4 inline-flex w-fit items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold"
              style={`background-color: ${t.accent}1A; color: ${t.accent};`}
            >
              ★ {t.metric}
            </div>
          )}
          <blockquote class="flex-1 text-sm leading-relaxed text-foreground">
            &ldquo;{t.quote}&rdquo;
          </blockquote>
          <figcaption class="mt-5 flex items-center gap-3 border-t pt-4">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold text-white"
              style={`background-color: ${t.accent};`}
              aria-hidden="true"
            >
              {t.initials}
            </div>
            <div class="min-w-0">
              <div class="truncate text-sm font-semibold">{t.name}</div>
              <div class="truncate text-xs text-muted-foreground">{t.role} · {t.clinic}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="/case-studies/nur-klinika" class="text-sm font-semibold text-[#2563EB] hover:underline">
        To'liq muvaffaqiyat hikoyasini o'qish &rarr;
      </a>
    </div>
  </div>
</section>

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'Clary — Klinika SaaS',
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '50',
    },
    review: items.map((t) => ({
      '@type': 'Review',
      author: { '@type': 'Person', name: t.name },
      reviewBody: t.quote,
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
    })),
  })}
/>

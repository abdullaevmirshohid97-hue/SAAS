    posthog.init(phKey, { api_host: phHost, person_profiles: 'identified_only', capture_pageview: true, autocapture: false });

    // UTM persistence (first-touch + last-touch, 30d cookie)
    (function() {
      var p = new URLSearchParams(window.location.search);
      var keys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
      var hasUtm = keys.some(function(k){ return p.has(k); });
      if (hasUtm) {
        var lastTouch = {};
        keys.forEach(function(k){ if(p.has(k)) lastTouch[k] = p.get(k); });
        document.cookie = 'clary_last_touch=' + encodeURIComponent(JSON.stringify(lastTouch)) + ';path=/;max-age=2592000;samesite=lax';
        if (!document.cookie.includes('clary_first_touch=')) {
          document.cookie = 'clary_first_touch=' + encodeURIComponent(JSON.stringify(lastTouch)) + ';path=/;max-age=15552000;samesite=lax';
        }
        try { posthog.register({ first_touch: lastTouch, last_touch: lastTouch }); } catch(e) {}
      }
    })();
  </script>
)}


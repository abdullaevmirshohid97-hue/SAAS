---
// Programmatic SEO landing — solutions / for / regions sahifalari uchun
// umumiy layout. Base.astro orqali canonical/hreflang/FAQPage avtomatik.
import Base from '../layouts/Base.astro';
import type { Lang } from '../data/seo-pages';

export interface SeoLandingProps {
  lang: Lang;
  metaTitle: string;
  metaDescription: string;
  h1: string;
  intro: string;
  /** AI SEO — qisqa xulosa bloki. Ixtiyoriy. */
  tldr?: string;
  /** AI SEO — ta'rif ("X nima?") bloki. Ixtiyoriy. */
  definition?: string;
  benefits: string[];
  faq: Array<{ question: string; answer: string }>;
  /** Ichki havolalar — internal linking uchun. */
  links: Array<{ label: string; href: string }>;
  breadcrumbs: Array<{ name: string; url: string }>;
}

const {
  lang,
  metaTitle,
  metaDescription,
  h1,
  intro,
  tldr,
  definition,
  benefits,
  faq,
  links,
  breadcrumbs,
} = Astro.props as SeoLandingProps;

const astroLocale = lang === 'ru' ? 'ru' : 'uz-Latn';
const t = {
  benefitsTitle: lang === 'ru' ? 'Что вы получаете' : 'Nima olasiz',
  faqTitle: lang === 'ru' ? 'Частые вопросы' : 'Ko‘p beriladigan savollar',
  relatedTitle: lang === 'ru' ? 'Смотрите также' : 'Yana ko‘ring',
  ctaPrimary: lang === 'ru' ? 'Начать бесплатно →' : 'Bepul boshlash →',
  ctaSecondary: lang === 'ru' ? 'Записаться на демо' : 'Demoga yozilish',
  tldrLabel: lang === 'ru' ? 'Коротко' : 'Qisqacha',
};
const signupHref = lang === 'ru' ? '/ru/signup' : '/signup';
---
<Base
  title={metaTitle}
  description={metaDescription}
  locale={astroLocale}
  breadcrumbs={breadcrumbs}
  faq={faq}
>
  <article class="container mx-auto max-w-4xl px-4 py-16">
    <!-- Breadcrumb (ko'rinadigan) -->
    <nav class="text-xs text-muted-foreground" aria-label="breadcrumb">
      {breadcrumbs.map((b, i) => (
        <span>
          {i > 0 && <span class="mx-1">/</span>}
          {i < breadcrumbs.length - 1 ? (
            <a href={b.url} class="hover:text-foreground">{b.name}</a>
          ) : (
            <span>{b.name}</span>
          )}
        </span>
      ))}
    </nav>

    <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">{h1}</h1>

    {/* AI SEO — TLDR bloki (ChatGPT/Claude iqtibos oladi) */}
    {tldr && (
      <div class="mt-5 rounded-lg border-l-4 border-[#2563EB] bg-[#2563EB]/5 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-[#2563EB]">
          {t.tldrLabel}
        </div>
        <p class="mt-1 text-sm leading-relaxed">{tldr}</p>
      </div>
    )}

    <p class="mt-5 text-lg leading-relaxed text-muted-foreground">{intro}</p>

    {/* AI SEO — ta'rif bloki ("X nima?") */}
    {definition && (
      <div class="mt-6 rounded-lg border bg-card p-5">
        <p class="text-sm leading-relaxed">{definition}</p>
      </div>
    )}

    <!-- Benefits -->
    <h2 class="mt-12 text-2xl font-bold tracking-tight">{t.benefitsTitle}</h2>
    <ul class="mt-5 grid gap-3 md:grid-cols-2">
      {benefits.map((b) => (
        <li class="flex gap-2 rounded-lg border bg-card p-4 text-sm">
          <span class="font-bold text-[#10B981]">✓</span>
          <span>{b}</span>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="mt-10 flex flex-col gap-3 sm:flex-row">
      <a
        href={signupHref}
        class="rounded-md bg-[#2563EB] px-6 py-3 text-center text-sm font-semibold text-white hover:bg-[#1D4ED8]"
      >
        {t.ctaPrimary}
      </a>
      <a
        href="/book-demo"
        class="rounded-md border px-6 py-3 text-center text-sm font-semibold hover:bg-accent"
      >
        {t.ctaSecondary}
      </a>
    </div>

    <!-- FAQ -->
    {faq.length > 0 && (
      <section class="mt-14">
        <h2 class="text-2xl font-bold tracking-tight">{t.faqTitle}</h2>
        <div class="mt-5 space-y-3">
          {faq.map((f) => (
            <details class="rounded-lg border bg-card p-4">
              <summary class="cursor-pointer text-sm font-semibold">{f.question}</summary>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{f.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Internal links -->
    {links.length > 0 && (
      <section class="mt-14">
        <h2 class="text-2xl font-bold tracking-tight">{t.relatedTitle}</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {links.map((l) => (
            <a
              href={l.href}
              class="rounded-full border bg-card px-4 py-1.5 text-sm hover:border-[#2563EB] hover:text-[#2563EB]"
            >
              {l.label}
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Base>

---
import BrandLogo from './BrandLogo.astro';
import { REGIONS } from '../data/seo-pages';
export interface Props { year: number }
const { year } = Astro.props;
// demo.astro bilan bir xil pattern — ASTRO_PUBLIC_API_URL klient skriptida
// undefined bo'lib qoladi, shuning uchun PUBLIC_API_BASE_URL + fallback.
const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? 'https://api.clary.uz';
---
<footer class="border-t border-border/40 bg-muted/20">
  <div class="container mx-auto grid gap-10 px-4 py-12 md:grid-cols-5">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-semibold">
        <BrandLogo size={28} />
        <span class="flex flex-col leading-tight">
          <span>Clary</span>
          <span class="text-[10px] font-normal uppercase tracking-wide text-muted-foreground">Healthcare ERP</span>
        </span>
      </div>
      <p class="mt-3 max-w-sm text-sm text-muted-foreground">Healthcare ERP va klinika boshqaruv tizimi — Uzbekistan va CIS uchun. Reception, kassa, laboratoriya, dorixona, statsionar va analitika bitta platformada.</p>
      <form id="newsletter-form" class="mt-4 flex max-w-sm gap-2">
        <input type="email" name="email" placeholder="Email" required class="h-9 flex-1 rounded-md border bg-background px-3 text-sm" />
        <button type="submit" class="rounded-md bg-[#2563EB] px-3 text-sm font-semibold text-white">Obuna</button>
      </form>
      <p id="newsletter-msg" class="mt-2 hidden max-w-sm text-xs"></p>
    </div>
    <div>
      <div class="text-sm font-semibold">Mahsulot</div>
      <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
        <li><a href="/features" class="hover:text-foreground">Imkoniyatlar</a></li>
        <li><a href="/pricing" class="hover:text-foreground">Tariflar</a></li>
        <li><a href="/integrations" class="hover:text-foreground">Integratsiyalar</a></li>
        <li><a href="/changelog" class="hover:text-foreground">O'zgarishlar</a></li>
        <li><a href="/use-cases" class="hover:text-foreground">Foydalanish hollari</a></li>
        <li><a href="/download" class="hover:text-foreground">Bemor ilovasi</a></li>
        <li><a href="/book-demo" class="hover:text-foreground">Demo</a></li>
      </ul>
    </div>
    <div>
      <div class="text-sm font-semibold">Kompaniya</div>
      <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
        <li><a href="/about" class="hover:text-foreground">Biz haqimizda</a></li>
        <li><a href="/team" class="hover:text-foreground">Jamoa</a></li>
        <li><a href="/vs" class="hover:text-foreground">Taqqoslash</a></li>
        <li><a href="/contact" class="hover:text-foreground">Aloqa</a></li>
        <li><a href="/blog" class="hover:text-foreground">Blog</a></li>
        <li><a href="/docs" class="hover:text-foreground">Hujjatlar</a></li>
        <li><a href="https://status.clary.uz" class="hover:text-foreground">Holat</a></li>
      </ul>
    </div>
    <div>
      <div class="text-sm font-semibold">Huquqiy</div>
      <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
        <li><a href="/legal/terms" class="hover:text-foreground">Shartlar</a></li>
        <li><a href="/legal/privacy" class="hover:text-foreground">Maxfiylik</a></li>
        <li><a href="/legal/dpa" class="hover:text-foreground">DPA</a></li>
        <li><a href="/legal/sla" class="hover:text-foreground">SLA</a></li>
        <li><a href="/legal/security" class="hover:text-foreground">Xavfsizlik</a></li>
        <li><a href="/legal/cookies" class="hover:text-foreground">Cookies</a></li>
        <li><a href="/legal/acceptable-use" class="hover:text-foreground">Foydalanish</a></li>
        <li><a href="/legal/compliance" class="hover:text-foreground">Compliance</a></li>
      </ul>
    </div>
  </div>
  {/* Shaharlar — local SEO ichki havolalar (regions sahifalari) */}
  <div class="border-t border-border/40 py-4">
    <div class="container mx-auto flex flex-wrap items-center justify-center gap-x-4 gap-y-1 px-4 text-xs text-muted-foreground">
      <span class="font-medium">Klinika dasturi:</span>
      {REGIONS.map((r) => (
        <a href={`/regions/${r.slug}`} class="hover:text-foreground hover:underline">{r.city.uz}</a>
      ))}
    </div>
  </div>
  <div class="border-t border-border/40 py-5 text-center text-xs text-muted-foreground">
    &copy; {year} Clary LLC. All rights reserved. &middot; clary.uz
  </div>
</footer>

<script define:vars={{ apiBase }}>
  // Footer obuna formasi — email'ni leads sifatida yuboradi (source: newsletter).
  const form = document.getElementById('newsletter-form');
  const msg = document.getElementById('newsletter-msg');
  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = new FormData(form).get('email');
      const btn = form.querySelector('button');
      if (btn) { btn.disabled = true; btn.textContent = '...'; }
      try {
        const res = await fetch(`${apiBase}/api/v1/leads`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'newsletter' }),
        });
        if (!res.ok) throw new Error('request failed');
        form.classList.add('hidden');
        msg.textContent = "Rahmat! Obuna bo'ldingiz ✓";
        msg.classList.remove('hidden');
        msg.classList.add('text-emerald-600');
      } catch {
        msg.textContent = "Xatolik yuz berdi — keyinroq qayta urinib ko'ring.";
        msg.classList.remove('hidden');
        msg.classList.add('text-rose-600');
        if (btn) { btn.disabled = false; btn.textContent = 'Obuna'; }
      }
    });
  }
</script>

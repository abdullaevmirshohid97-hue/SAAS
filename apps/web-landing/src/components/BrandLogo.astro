---
// Clary "professor boyqush" brend belgisi — landing uchun inline SVG.
// ui-web/ClaryLogo bilan bir xil dizayn (Astro React komponent ishlatmaydi).
export interface Props {
  /** Belgi o'lchami (px). Default 28. */
  size?: number;
  class?: string;
}
const { size = 28, class: className = '' } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Clary"
  class={className}
>
  <defs>
    <linearGradient id="clary-owl-grad" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#3B82F6" />
      <stop offset="100%" stop-color="#2563EB" />
    </linearGradient>
  </defs>
  <rect x="0" y="0" width="40" height="40" rx="10" fill="url(#clary-owl-grad)" />
  <path d="M11 11 L9.5 4 L15 9 Z" fill="#fff" />
  <path d="M29 11 L30.5 4 L25 9 Z" fill="#fff" />
  <ellipse cx="20" cy="22" rx="13" ry="13.5" fill="#fff" />
  <circle cx="15" cy="20" r="4.2" fill="#0f172a" />
  <circle cx="25" cy="20" r="4.2" fill="#0f172a" />
  <circle cx="13.8" cy="18.8" r="1.3" fill="#fff" />
  <circle cx="23.8" cy="18.8" r="1.3" fill="#fff" />
  <circle cx="15" cy="20" r="5.6" fill="none" stroke="#0f172a" stroke-width="1.5" />
  <circle cx="25" cy="20" r="5.6" fill="none" stroke="#0f172a" stroke-width="1.5" />
  <line x1="20.6" y1="20" x2="19.4" y2="20" stroke="#0f172a" stroke-width="1.5" stroke-linecap="round" />
  <path d="M20 25 L17 30 L20 32.5 L23 30 Z" fill="#F59E0B" />
</svg>

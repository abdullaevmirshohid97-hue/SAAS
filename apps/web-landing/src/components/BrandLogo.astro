---
// Clary metall "Clary" wordmark — qora yumaloq chip (brend rasm).
// Manba: public/clary-wordmark.png (gen-brand-assets.mjs orqali). Crescent emas.
export interface Props {
  /** Balandlik (px). Default 32. */
  height?: number;
  class?: string;
}
const { height = 32, class: className = '' } = Astro.props;
---
<img
  src="/clary-wordmark.png"
  alt="Clary"
  draggable={false}
  style={`height:${height}px;width:auto`}
  class={`select-none ${className}`}
/>

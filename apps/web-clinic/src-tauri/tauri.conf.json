{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clary",
  "version": "0.1.1",
  "identifier": "uz.clary.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web-clinic dev",
    "beforeBuildCommand": "pnpm --filter web-clinic build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clary — Klinika boshqaruvi",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.clary.uz https://*.supabase.co wss://*.supabase.co https://*.posthog.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["resources/SumatraPDF.exe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://clary.uz/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDOEU3REMwODQ0REY1MjUKUldRbDlVMkV3SDJPVENiQTBXUlQ3cE9GTzZZUExpQXhxcjdTUkZRSEY2WXN1cWVyeHBaMkYvVWwK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["clary"]
      }
    }
  }
}

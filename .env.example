# ============================================================================
# Clary v2 — Environment variables example
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

NODE_ENV=development
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# Supabase (https://supabase.com)
# Project ref: aoubdvlkcatbeifuysau (v2 greenfield)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://aoubdvlkcatbeifuysau.supabase.co
SUPABASE_ANON_KEY=<ANON_KEY_HERE>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY_HERE>
SUPABASE_JWT_SECRET=<JWT_SECRET_HERE>
SUPABASE_PROJECT_REF=aoubdvlkcatbeifuysau
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.aoubdvlkcatbeifuysau.supabase.co:5432/postgres

# Frontend-exposed (prefixed)
VITE_SUPABASE_URL=https://aoubdvlkcatbeifuysau.supabase.co
VITE_SUPABASE_ANON_KEY=<ANON_KEY_HERE>
EXPO_PUBLIC_SUPABASE_URL=https://aoubdvlkcatbeifuysau.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY_HERE>

# ----------------------------------------------------------------------------
# API
# ----------------------------------------------------------------------------
API_PORT=4000
API_BASE_URL=http://localhost:4000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4321
API_JWT_ISSUER=https://aoubdvlkcatbeifuysau.supabase.co/auth/v1
API_JWT_AUDIENCE=authenticated

# Frontend-exposed
VITE_API_URL=http://localhost:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# ----------------------------------------------------------------------------
# Redis (BullMQ)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----------------------------------------------------------------------------
# Stripe (Clary platform subscription billing)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_<KEY>
STRIPE_WEBHOOK_SECRET=whsec_<SECRET>
STRIPE_PUBLISHABLE_KEY=pk_test_<KEY>
STRIPE_PRICE_25PRO=price_<ID>
STRIPE_PRICE_50PRO=price_<ID>
STRIPE_PRICE_120PRO=price_<ID>

# ----------------------------------------------------------------------------
# Telegram bot (daily backup summary)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<BOT_TOKEN>
TELEGRAM_CHAT_ID=<FOUNDER_CHAT_ID>

# ----------------------------------------------------------------------------
# Backblaze B2 (weekly encrypted backup)
# ----------------------------------------------------------------------------
B2_KEY_ID=<B2_KEY_ID>
B2_APPLICATION_KEY=<B2_APP_KEY>
B2_BUCKET=clary-backups
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKUP_AGE_RECIPIENT=age1<PUBLIC_KEY>

# ----------------------------------------------------------------------------
# Cloudflare (DNS + Turnstile CAPTCHA)
# ----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=<TOKEN>
CLOUDFLARE_ZONE_ID=<ZONE_ID>
TURNSTILE_SITE_KEY=<SITE_KEY>
TURNSTILE_SECRET_KEY=<SECRET_KEY>
VITE_TURNSTILE_SITE_KEY=<SITE_KEY>
ASTRO_PUBLIC_TURNSTILE_SITE_KEY=<SITE_KEY>

# ----------------------------------------------------------------------------
# Google OAuth (Gmail sign-in)
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=<CLIENT_ID>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<CLIENT_SECRET>
GOOGLE_REDIRECT_URI=https://aoubdvlkcatbeifuysau.supabase.co/auth/v1/callback

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
SENTRY_DSN=https://<DSN>@glitchtip.clary.uz/1
SENTRY_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
POSTHOG_API_KEY=<POSTHOG_KEY>
POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_KEY=<POSTHOG_KEY>
VITE_POSTHOG_HOST=https://app.posthog.com

# ----------------------------------------------------------------------------
# Public landing (Astro)
# ----------------------------------------------------------------------------
ASTRO_PUBLIC_SITE_URL=https://clary.uz
ASTRO_PUBLIC_API_URL=https://api.clary.uz
ASTRO_PUBLIC_APP_URL=https://app.clary.uz
ASTRO_PUBLIC_CAL_LINK=clary/demo

# ----------------------------------------------------------------------------
# NOTE: Each clinic plugs in its own BYO credentials (SMS / payment / email)
# via the Settings > Integrations UI. These are stored encrypted in Supabase
# Vault (pgsodium). The following are PLATFORM-LEVEL fallbacks for public
# endpoints (e.g. Clary's own marketing SMS).
# ----------------------------------------------------------------------------
PLATFORM_ESKIZ_EMAIL=<EMAIL>
PLATFORM_ESKIZ_PASSWORD=<PASSWORD>
PLATFORM_RESEND_API_KEY=re_<KEY>
PLATFORM_RESEND_FROM="Clary <hello@clary.uz>"

# ----------------------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------------------
FEATURE_DESKTOP_APP=false
FEATURE_DICOM_VIEWER=false
FEATURE_PUBLIC_API=false

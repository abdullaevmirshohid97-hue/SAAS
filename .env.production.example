# ============================================================================
# Clary v2 — Production environment
# Copy to .env.production and fill in real values. NEVER commit .env.production.
# ============================================================================

# --- Supabase (clary.uz Supabase Cloud loyihangiz) --------------------------
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-from-supabase-dashboard

# Frontend variants (Vite build args)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=https://api.clary.uz

# --- API ---------------------------------------------------------------------
API_PORT=4000
API_CORS_ORIGINS=https://clary.uz,https://app.clary.uz,https://admin.clary.uz
WEB_CLINIC_URL=https://app.clary.uz

# --- Redis (compose ichida) -------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# --- Demo flow (S3) ---------------------------------------------------------
CRON_SECRET=CHANGE_ME_openssl_rand_hex_32
DEMO_IP_SALT=CHANGE_ME_openssl_rand_hex_32

# --- Leads (S7) -------------------------------------------------------------
LEADS_IP_SALT=CHANGE_ME_openssl_rand_hex_32
TELEGRAM_LEADS_BOT_TOKEN=1234567890:AAA-...
TELEGRAM_LEADS_CHAT_ID=-1001234567890

# --- Analytics (S8) ---------------------------------------------------------
PUBLIC_POSTHOG_KEY=phc_...
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
PUBLIC_CLARITY_ID=abcd1234ef
VITE_POSTHOG_KEY=phc_...

# --- Sentry (S11) -----------------------------------------------------------
SENTRY_DSN_API=
SENTRY_DSN_CLINIC=
SENTRY_DSN_LANDING=

# --- Optional: SMS, payments (BYO API) --------------------------------------
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
